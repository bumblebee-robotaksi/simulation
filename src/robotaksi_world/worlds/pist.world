    <!-- TUNEL: px(140,180)-(192,300), gercek surulebilir gecit.
         Govde 3.64m (X) genislik x 8.4m (Y) uzunluk x 3m ic yukseklik.
         Yol bu hucrenin icinden GECER (Y ekseni boyunca), govde collision'i
         SADECE yan duvarlarda (ust kapakta yok, arac alttan gecer). -->
    <model name="tunel_govde">
      <static>true</static>
      <pose>11.62 18.2 1.5 0 0 -0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>3.64 8.4 3.0</size></box></geometry>
          <material><ambient>0.1 0.2 0.55 1</ambient><diffuse>0.1 0.2 0.55 1</diffuse></material>
        </visual>
        <!-- ust kapakta collision yok; sadece gorsel. Yan duvarlar asagida
             ayri ince collision'li modeller olarak eklendi. -->
      </link>
    </model>
    <!-- Tunel yan duvarlari (collision'lu, arac icerde 2.6m'lik surus
         koridorunda kalir: 3.64m govde - 2x0.52m duvar payi) -->
