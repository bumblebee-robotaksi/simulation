<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="pist">

    <!--
      ===========================================================================
      PIST DUNYASI - v2 (pixel-map dogrulamali yeniden insa)

      Bu surum, Kaptan'in manuel olarak cikardigi piksel-koordinat haritasini
      (bina koseleri, tunel, rotonda, DURAK istasyonlari) TEMEL ALIR. Eski
      surumdeki "idealize edilmis 4x3 duzgun grid" yaklasimi birakildi; bunun
      yerine asagidaki donusum kullanildi:

        OLCEK: 1 piksel = 0.07 metre  (px -> world: world = px * 0.07)
        Bu deger, en sik tekrar eden bosluk olculerinden (binalar arasi
        ~38-45px yol bosluklari) ve arac (Bee1) govde genisligi 1.06m,
        govde uzunlugu 2.740m baz alinarak SECILDI:
          - 45px yol bosluğu -> 3.15m  (Bee1 genisliginin ~3x'i, manevra icin
            yeterli pay birakir, "dar yol" hissini korur)
          - 38px yol bosluğu -> 2.66m  (en dar koridor, hala govde
            genisliginin 2.5x'i uzerinde)

        ISTISNA - ROTONDA: piksel-dogru olcek (r=30px -> 2.1m yari cap) Bee1'in
        kendi govde uzunlugundan (2.74m) DAHA KUCUK bir ada uretiyordu — fiziksel
        olarak donulemez. Kaptan'in talimati ile SADECE rotonda buyutuldu:
        ada yari capi 2.0m, halka yol genisligi 3.0m, dis yari cap 5.0m.
        Diger her sey piksel haritasina sadik kaldi.

      KOORDINAT DONUSUMU (DUZELTILDI - bkz. "Y-EKSENI DUZELTMESI" notu):
        world_x = px_x * 0.07
        world_y = (35.0 - px_y) * 0.07_olceginde_zaten_uygulanmis -> yani
                  world_y = 35.0 - (px_y * 0.07)
        Tum modellerin pose'lari bu donusumle hesaplanmis VE kaydedilmistir
        (asagidaki her modelin <pose> degeri zaten world-frame, donusum
        ayrica uygulanmasi GEREKMEZ).

      *** Y-EKSENI DUZELTMESI (onemli, ilk surumde HATA vardi) ***
      Piksel haritasi standart GORUNTU eksenlerini kullanir: +Y ASAGI
      dogru buyur (sol-ust orijin). Gazebo/SDF world frame'inde ise,
      yukaridan-asagi (top-down) bir gorunumde +Y EKRANDA YUKARI dogru
      render edilir. Bu ikisini DOGRUDAN (px_y -> world_y, cevirmeden)
      esleyince, harita BASTAN AYAGA TERS donuyordu: Row1 (resmin EN
      USTU) Gazebo'da EKRANIN ALTINDA, Row3/LAST_DURAK (resmin EN ALTI)
      ise EKRANIN USTUNDE cikiyordu. Bu artik DUZELTILDI: world_y =
      35.0 - (px_y*0.07) ile Row1 en YUKSEK Y (ekranda ust), LAST_DURAK
      en DUSUK Y (ekranda alt) degerini aliyor - resimle ayni yonde.
      NOT: Bu bir sol-sag (X) ayna degil - X eksenine HICBIR ZAMAN
      dokunulmadi, sadece kuzey-guney (Y) eksen ters cevrildi.

      ANOMALY BINALAR (B6, B7, B9, B10): Kaptan'in talimati ile, her binanin
      TAM basamakli/L-sekilli poligonu yerine BASITLESTIRILMIS "tam dikdortgen
      eksi bir kose" modeli kullanildi (iki kutu: govde + L tamamlayici eksigi
      ile degil, dogrudan "ana gövde kutusu, notch bolgesi haric" olarak iki
      kutuya bolundu). Notch corner ve boyutlari her binanin orijinal
      poligon noktalarindan turetildi.

      DURAK (BUS/VEHICLE STOP) MANTIGI: "DURAK" bir bina ICINE oyulmus bir
      cep/alkov (recess) olarak modellenir - araç binanin notch'landigi
      bosluga girip duraklayabilir. B7_ANOMALY'nin notch'u icinde byle bir
      DURAK alkovu (B7 DURAK OVERRIDE) var. Bagimsiz DURAK'lar (DURAK_mid,
      LAST_DURAK) duz, isaretli yer pedleri olarak modellenir (bina degil,
      yol/meydan uzerinde).

      TUNEL: Gercek surulebilir gecit (duvarlar + tavan, ust kapakta
      collision yok, arac alttan gecer). Row2'de B5 ile B6 arasindaki hucreyi
      dolduruyor (px 140-192, y 180-300).

      PARK ALANI (Row1 sag uc, "Parking Lot special"): Gercek duvarli park
      alani + giris bosluğu + 4 park slotu (eski SDF'teki park_apron/
      park_slot mantigi, yeni boyut/konuma tasindi).
      ===========================================================================
    -->

    <include>
      <uri>model://sun</uri>
    </include>

    <include>
      <uri>model://ground_plane</uri>
    </include>

    <physics type="ode">
      <real_time_update_rate>1000.0</real_time_update_rate>
      <max_step_size>0.001</max_step_size>
    </physics>

    <!-- ===========================================================================
         GRID OZETI (referans - world metre cinsinden, olcek 0.07 m/px)
         Row1 (binalar): y ~ 4.76 - 9.45   (px 68-135, B4/ParkLot px 68-185/225)
         Row1-Row2 yatay yol: y ~ 9.45 - 12.6   (px 135-180)
         Row2 (binalar+tunel): y ~ 12.6 - 21.0  (px 180-300)
         Row2-Row3 yatay yol / rotonda bolgesi: y ~ 21.0 - 24.15  (px 300-345)
         Row3 (binalar): y ~ 23.8 - 28.7  (px 340-410)
         LAST_DURAK: y ~ 31.5 - 32.9  (px 450-470)

         Dikey yollar:
           col-road-1 (B1|B2 arasi): x ~ 10.64 - 13.44  (px 152-192)
           col-road-2 (B2|B3 arasi): x ~ 19.39 - 22.05  (px 277-315)
           col-road-3 (B3|B4 arasi): x ~ 28.84 - 31.29  (px 412-447)
         Sol kenar koridoru (DURAK_mid burada): x ~ 0 - 7.07  (px 0-101)
         =========================================================================== -->

    <!-- ============ ANA ZEMIN / YOL DOSEMESI ============
         Tum parkur alanini kaplayan tek buyuk asfalt zemin (binalar ve
         ozel alanlar bunun ustune yerlesir). Bu, eskisi gibi tek tek yol
         segmentleri cizmek yerine, piksel haritasindaki "binalar arasinda
         her yerde yol var" gercegini dogru yansitir. -->
    <model name="ana_zemin">
      <static>true</static>
      <pose>22.75 17.5 0.0 0 0 -0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>47 37 0.02</size></box></geometry>
          <material><ambient>0.25 0.25 0.27 1</ambient><diffuse>0.25 0.25 0.27 1</diffuse></material>
        </visual>
      </link>
    </model>

